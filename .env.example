# Server Configuration
NODE_ENV=development
PORT=3001
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql://sadcats:your_password_here@postgres:5432/sadcats
DB_POOL_MAX=20

# Redis
REDIS_URL=redis://redis:6379

# Discord OAuth
DISCORD_CLIENT_ID=1465860515296186584
DISCORD_CLIENT_SECRET=your_discord_client_secret_here
DISCORD_SERVER_ID=your_discord_server_id_here
DISCORD_CALLBACK_URL=https://api.sad-cats.org/api/auth/callback
DISCORD_API_URL=https://discord.com/api/v10

# JWT Configuration
JWT_SECRET=your_secure_random_secret_here_use_openssl_rand_base64_32
JWT_EXPIRES_IN=24h
JWT_ALGORITHM=HS256

# CORS
CORS_ORIGIN=https://sad-cats.org

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120

# WebSocket
WS_PING_INTERVAL=25000
WS_PING_TIMEOUT=5000
